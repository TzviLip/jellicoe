# ─── Supabase ─────────────────────────────────────────────────────────────────
# Get these from: Supabase dashboard → Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_KEY=your-service-role-key-here

# ─── Resend (email) ────────────────────────────────────────────────────────────
# Sign up at resend.com — free tier is plenty for this volume

RESEND_API_KEY=re_your_key_here
FROM_EMAIL=noreply@yourpractice.com

# ─── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Radiographer email (patient form sends here)
RADIOGRAPHER_EMAIL=radiographer@yourpractice.com

# ─── Phase 3 (Anthropic API for AI report) ────────────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ─── Internal secret (used to sign internal API calls) ────────────────────────
# Generate with: openssl rand -hex 32
INTERNAL_API_SECRET=replace-with-random-hex-string
