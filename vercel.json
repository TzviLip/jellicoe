{
  "headers": [
    {
      "source": "/.env(.*)",
      "headers": [{ "key": "x-robots-tag", "value": "noindex" }]
    }
  ],
  "rewrites": [],
  "redirects": [
    {
      "source": "/.env(.*)",
      "destination": "/404",
      "permanent": false
    },
    {
      "source": "/.git(.*)",
      "destination": "/404",
      "permanent": false
    }
  ]
}
